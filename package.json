{
    "private": true,
    "pnpm": {
        "onlyBuiltDependencies": [
            "cypress",
            "esbuild"
        ]
    },
    "scripts": {
        "lint": "pnpm -r lint",
        "typecheck": "pnpm -r typecheck",
        "build": "pnpm -r build",
        "dev:web": "pnpm --filter web dev",
        "dev:landing": "pnpm --filter landing dev",
        "dev:api": "pnpm --filter api dev",
        "build:web": "pnpm --filter web build",
        "build:landing": "pnpm --filter landing build",
        "start:web": "pnpm --filter web start -p 3000",
        "start:landing": "pnpm --filter landing start -p 3001",
        "start:api": "pnpm --filter api start -p 3002",
        "e2e:web": "pnpm --filter e2e run e2e:web",
        "e2e:landing": "pnpm --filter e2e run e2e:landing",
        "e2e:api": "pnpm --filter e2e run e2e:api",
        "azure:deploy": "bash infra/deploy.sh all",
        "azure:setup": "bash infra/deploy.sh setup",
        "azure:push": "bash infra/deploy.sh deploy",
        "azure:status": "bash infra/deploy.sh status",
        "azure:destroy": "bash infra/deploy.sh destroy"
    },
    "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316"
}