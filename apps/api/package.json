    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "scrapingbee": "^1.8.2",
    "sequelize": "^6.37.7",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
